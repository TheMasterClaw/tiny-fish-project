{
  "name": "coralguard",
  "version": "1.0.0",
  "description": "CoralGuard combines AI agents with blockchain to monitor, protect, and restore marine ecosystems.",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.js --network hardhat",
    "deploy:base-sepolia": "hardhat run scripts/deploy.js --network baseSepolia",
    "verify:base-sepolia": "hardhat verify --network baseSepolia",
    "node": "hardhat node",
    "frontend:dev": "cd frontend && npm start",
    "frontend:build": "cd frontend && npm run build",
    "frontend:deploy": "cd frontend && npm run deploy",
    "build": "cd frontend && npm install && npm run build",
    "vercel-build": "cd frontend && npm install --legacy-peer-deps && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheMasterClaw/tiny-fish-project.git"
  },
  "keywords": [
    "blockchain",
    "ethereum",
    "conservation",
    "coral",
    "reef",
    "marine",
    "ocean",
    "nft",
    "base",
    "ai"
  ],
  "author": "CoralGuard Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/TheMasterClaw/tiny-fish-project/issues"
  },
  "homepage": "https://coralguard.io",
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@pinata/sdk": "^2.1.0"
  },
  "type": "commonjs",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "hardhat": "^2.28.6",
    "playwright": "^1.58.2"
  }
}
